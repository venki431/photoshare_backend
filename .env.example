# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Option 1: Connection string (preferred — works with Supabase, Neon, Railway, etc.)
DATABASE_URL=postgresql://postgres:password@localhost:5432/photoshare

# Option 2: Individual variables (used as fallback when DATABASE_URL is not set)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=photoshare
PG_USER=postgres
PG_PASSWORD=
PG_SSL=false
PG_POOL_MAX=20

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10

# ─── Email (used for sending OTP codes) ────────────────────────────────────────
# Set SMTP_ENABLED=false to skip email and just log the OTP to the console (dev mode)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM=PhotoShare <noreply@photoshare.app>

# ─── File Uploads ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=25

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
